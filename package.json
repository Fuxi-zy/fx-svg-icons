{
  "name": "@fuxishi/svg-icon",
  "version": "1.0.7-alpha.0",
  "description": "Vue 3 图标组件，支持 Iconify 图标集和本地 SVG",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.cjs"
    },
    "./virtual": {
      "types": "./dist/virtual.d.ts"
    },
    "./dist/style.css": "./dist/svg-icon.css"
  },
  "files": [
    "dist",
    "README_EN.md"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "typecheck": "vue-tsc --noEmit",
    "ncu": "ncu -u && pnpm install",
    "login": "npm login --registry=https://registry.npmjs.org/",
    "pub": "npm publish --access public --registry=https://registry.npmjs.org/",
    "pub-tag": "npm publish --access public --tag alpha --registry=https://registry.npmjs.org/",
    "deprecate": "node -e \"const v=process.argv[1],m=process.argv[2]||'';require('child_process').execSync('npm deprecate @fuxishi/svg-icon@'+v+' \\\"'+m+'\\\" --registry=https://registry.npmjs.org/',{stdio:'inherit'})\""
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0"
  },
  "peerDependencies": {
    "vue": "^3.5.33"
  },
  "peerDependenciesMeta": {
    "element-plus": {
      "optional": true
    },
    "naive-ui": {
      "optional": true
    },
    "antdv-next": {
      "optional": true
    },
    "tdesign-vue-next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.7"
  },
  "keywords": [
    "vue3",
    "icon",
    "iconify",
    "svg",
    "element-plus"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Fuxi-zy/fx-svg-icons.git"
  },
  "bugs": {
    "url": "https://github.com/Fuxi-zy/fx-svg-icons/issues"
  },
  "homepage": "https://fuxi-zy.github.io/fx-svg-icons/",
  "packageManager": "pnpm@10.33.2",
  "license": "MIT"
}
